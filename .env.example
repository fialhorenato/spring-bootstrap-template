# Spring Bootstrap Template - Environment Variables
# Copy this file to .env and update with your values

# Application Server
PORT=8080

# JWT Configuration
JWT_SECRET=your-super-secret-key-minimum-32-chars-long
JWT_EXPIRATION_MS=86400000  # 24 hours

# Database Configuration
SPRING_PROFILES_ACTIVE=default

# For local-postgresql profile
# DATABASE_URL=jdbc:postgresql://localhost:5432/your_database_name
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=postgres

# For render profile
# DATABASE_URL=jdbc:postgresql://your-database.render.com:5432/your_database
# DATABASE_USERNAME=your_username
# DATABASE_PASSWORD=your_password

# CI/CD (Optional)
CODECOV_TOKEN=your_codecov_token
SNYK_TOKEN=your_snyk_token

# Render Deployment (Optional)
# RENDER_DEPLOY_HOOK_URL=https://api.github.com/repos/YOUR_REPO/dispatches
